# OFW-NET Server Configuration
# ============================

# Server Port (Render will override this)
PORT=3000

# SECURITY - CHANGE THESE PASSWORDS!
# Use a mix of letters, numbers, and special characters
STAFF_PASSWORD=MySecureStaffPassword2024!
MONITOR_PASSWORD=MySecureMonitorPassword2024!

# Database path (relative to server folder)
DATABASE_PATH=./data/pisonet.db

# Node environment
NODE_ENV=production

# Optional: Enable debug logging
DEBUG=false